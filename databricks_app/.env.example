# ── Databricks Workspace ──────────────────────────────────────────────────────
# Server hostname — copy from: SQL Warehouse → Connection details → Server hostname
# Do NOT include https://
DATABRICKS_HOST=adb-1234567890123456.7.azuredatabricks.net

# Personal Access Token — for local dev and bootcamp use
# Generate at: Workspace → top-right avatar → Settings → Developer → Access tokens
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SQL Warehouse HTTP path — leave blank to auto-discover (recommended)
# If you want to pin a specific warehouse, copy from:
#   SQL Warehouse → Connection details → HTTP path
DATABRICKS_HTTP_PATH=

# Unity Catalog (recommended) — leave blank to use warehouse defaults
# Find your catalog: Data → Catalog (left nav)
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default

# ── LLM Settings ─────────────────────────────────────────────────────────────
# When DATABRICKS_HOST is set, defaults to Databricks Model Serving.
# The workspace token above doubles as the LLM API key — no extra credentials.
#
# Override to use Claude, OpenAI, or Azure OpenAI:

# Option A — Databricks Model Serving (default, no changes needed)
# LLM_BASE_URL=https://{DATABRICKS_HOST}/serving-endpoints
# LLM_MODEL=databricks-meta-llama-3-3-70b-instruct
# LLM_API_KEY={same as DATABRICKS_TOKEN}

# Option B — OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Option C — Azure OpenAI
# LLM_BASE_URL=https://{your-resource}.openai.azure.com/openai/deployments/{deployment-name}
# LLM_MODEL=gpt-4o
# LLM_API_KEY={azure-openai-key}

# Option D — Local Ollama (no API key needed)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama
