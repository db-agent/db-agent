# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — good for demo and development)
DB_URL=sqlite:///./data/demo.db

# PostgreSQL (production example)
# DB_URL=postgresql://user:password@localhost:5432/dbagent

# MySQL (production example)
# DB_URL=mysql+pymysql://user:password@localhost:3306/dbagent

# ── LLM Provider ─────────────────────────────────────────────────────────────
# OpenAI
LLM_BASE_URL=https://models.github.ai/inference
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# GitHub Models (free tier)
# LLM_BASE_URL=https://models.inference.ai.azure.com
# LLM_API_KEY=ghp_...
# LLM_MODEL=gpt-4o-mini

# Groq (fast, free tier)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama3-8b-8192

# Ollama (fully local)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
# Set in frontend/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:8000
