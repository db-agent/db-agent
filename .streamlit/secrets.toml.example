# .streamlit/secrets.toml.example — Template for Streamlit Community Cloud secrets.
#
# Local dev:
#   Copy this file to .streamlit/secrets.toml and fill in your values.
#   (.streamlit/secrets.toml is gitignored.)
#
# Streamlit Cloud:
#   Don't commit secrets.toml. Paste the values into:
#       App settings → Secrets
#   Streamlit injects them as st.secrets at runtime.
#
# All keys here are also readable from the standard environment, so the same
# .env file works for non-Streamlit-Cloud deploys (Docker, Render, Fly.io …).

# ── LLM ──────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint works.

# OpenAI
LLM_BASE_URL = "https://api.openai.com/v1"
LLM_API_KEY  = "sk-..."
LLM_MODEL    = "gpt-4o-mini"

# GitHub Models (free tier — great for demos)
# LLM_BASE_URL = "https://models.github.ai/inference"
# LLM_API_KEY  = "ghp_..."
# LLM_MODEL    = "openai/gpt-4o-mini"

# Groq
# LLM_BASE_URL = "https://api.groq.com/openai/v1"
# LLM_API_KEY  = "gsk_..."
# LLM_MODEL    = "llama-3.1-8b-instant"

# ── Database ─────────────────────────────────────────────────────────────────
# Default: bundled SQLite demo DB (auto-seeded on first boot — no value needed)
# DB_URL = "sqlite:///./data/demo.db"

# Postgres
# DB_URL = "postgresql+psycopg2://user:password@host:5432/mydb"

# MySQL
# DB_URL = "mysql+pymysql://user:password@host:3306/mydb"
