# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
**/.env
# keep examples committed
!.env.example
!**/.env.example

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
**/.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Databases ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
# but keep the data/ directory itself
!**/data/.gitkeep

# ── Build / packaging ─────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
application.log

# ── Misc ──────────────────────────────────────────────────────────────────────
.claude/
